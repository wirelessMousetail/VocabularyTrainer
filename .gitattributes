# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# These files are text and should be normalized (LF on checkout)
*.cs text diff=csharp
*.csproj text
*.sln text
*.md text
*.json text
*.xml text
*.xaml text
*.axaml text

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
