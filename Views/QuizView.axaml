<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VocabularyTrainer.ViewModels"
        x:Class="VocabularyTrainer.Views.QuizView"
        x:DataType="vm:QuizViewModel"
        Title="VocabularyTrainer Quiz"
        Width="450" Height="400"
        MinWidth="350" MinHeight="300"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        PointerPressed="Window_PointerPressed">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="TextBlock.question">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style Selector="TextBlock.result">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>
    </Window.Styles>

    <Panel>
        <StackPanel Margin="24" VerticalAlignment="Center">
            <!-- Question -->
            <TextBlock Text="{Binding Question}"
                       Classes="question"/>

            <!-- Answer Buttons -->
            <ItemsControl ItemsSource="{Binding AnswerOptions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}"
                                Command="{Binding $parent[Window].DataContext.AnswerCommand}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Result Message -->
            <TextBlock Text="{Binding ResultMessage}"
                       Foreground="{Binding ResultColor}"
                       Classes="result"
                       IsVisible="{Binding ResultMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
    </Panel>
</Window>
